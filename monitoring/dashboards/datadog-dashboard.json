{
  "$schema": "https://docs.datadoghq.com/api/latest/dashboards/",
  "_comment": "Default Datadog dashboard. Replace {{service}} with your service name. Import via Datadog API.",
  "title": "Service Overview - {{service}}",
  "description": "Key metrics for {{service}} — request rate, errors, and latency.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "title": "Request Rate",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{service:{{service}},env:production}.as_rate()",
            "display_type": "line",
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            }
          }
        ],
        "yaxis": {
          "label": "requests/sec",
          "include_zero": true
        }
      },
      "layout": { "x": 0, "y": 0, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Error Rate",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{service:{{service}},env:production}.as_rate()",
            "display_type": "bars",
            "style": {
              "palette": "warm"
            }
          }
        ],
        "yaxis": {
          "label": "errors/sec",
          "include_zero": true
        }
      },
      "layout": { "x": 6, "y": 0, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Latency Percentiles",
        "type": "timeseries",
        "requests": [
          {
            "q": "p50:trace.http.request.duration{service:{{service}},env:production}",
            "display_type": "line",
            "style": { "palette": "green" },
            "metadata": [{ "alias_name": "P50" }]
          },
          {
            "q": "p90:trace.http.request.duration{service:{{service}},env:production}",
            "display_type": "line",
            "style": { "palette": "orange" },
            "metadata": [{ "alias_name": "P90" }]
          },
          {
            "q": "p95:trace.http.request.duration{service:{{service}},env:production}",
            "display_type": "line",
            "style": { "palette": "red" },
            "metadata": [{ "alias_name": "P95" }]
          },
          {
            "q": "p99:trace.http.request.duration{service:{{service}},env:production}",
            "display_type": "line",
            "style": { "palette": "purple" },
            "metadata": [{ "alias_name": "P99" }]
          }
        ],
        "yaxis": {
          "label": "seconds",
          "include_zero": true
        }
      },
      "layout": { "x": 0, "y": 3, "width": 12, "height": 3 }
    },
    {
      "definition": {
        "title": "Error Rate (%)",
        "type": "query_value",
        "requests": [
          {
            "q": "100 * sum:trace.http.request.errors{service:{{service}},env:production}.as_count() / sum:trace.http.request.hits{service:{{service}},env:production}.as_count()",
            "aggregator": "avg"
          }
        ],
        "precision": 2,
        "custom_unit": "%",
        "conditional_formats": [
          { "comparator": ">", "value": 5, "palette": "white_on_red" },
          { "comparator": ">", "value": 1, "palette": "white_on_yellow" },
          { "comparator": "<=", "value": 1, "palette": "white_on_green" }
        ]
      },
      "layout": { "x": 0, "y": 6, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "P95 Latency",
        "type": "query_value",
        "requests": [
          {
            "q": "p95:trace.http.request.duration{service:{{service}},env:production}",
            "aggregator": "avg"
          }
        ],
        "precision": 3,
        "custom_unit": "s",
        "conditional_formats": [
          { "comparator": ">", "value": 2, "palette": "white_on_red" },
          { "comparator": ">", "value": 0.5, "palette": "white_on_yellow" },
          { "comparator": "<=", "value": 0.5, "palette": "white_on_green" }
        ]
      },
      "layout": { "x": 3, "y": 6, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Throughput",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{service:{{service}},env:production}.as_rate()",
            "aggregator": "avg"
          }
        ],
        "precision": 1,
        "custom_unit": "req/s"
      },
      "layout": { "x": 6, "y": 6, "width": 3, "height": 2 }
    },
    {
      "definition": {
        "title": "Top Endpoints by Error Count",
        "type": "toplist",
        "requests": [
          {
            "q": "top(sum:trace.http.request.errors{service:{{service}},env:production} by {resource_name}.as_count(), 10, 'sum', 'desc')"
          }
        ]
      },
      "layout": { "x": 9, "y": 6, "width": 3, "height": 2 }
    }
  ]
}
