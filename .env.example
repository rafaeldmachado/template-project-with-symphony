# Project configuration
# Copy this to .env and fill in your values.
# See docs/SETUP.md for detailed instructions.

# ── GitHub ──────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# GitHub Projects (for issue tracking board)
# Create a project at github.com/orgs/<owner>/projects and note the number.
GITHUB_PROJECT_NUMBER=
# A PAT with `project` scope for syncing issues to the project board.
PROJECT_TOKEN=

# ── Deploy (ephemeral PR previews) ─────────
# Provider: vercel | netlify | cloudflare | fly | custom
# See docs/DEPLOY.md for provider-specific setup.
DEPLOY_PROVIDER=
DEPLOY_TOKEN=
DEPLOY_PROJECT_ID=

# ── Monitoring ──────────────────────────────
# Provider: sentry | datadog | grafana | custom
MONITOR_DSN=
MONITOR_ENV=development

# ── AI Agent (for Symphony autonomous mode) ─
# Set agent.name in WORKFLOW.md and add the corresponding key here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
